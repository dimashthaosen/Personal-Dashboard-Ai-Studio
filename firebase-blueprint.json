{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A pending or completed task item",
      "type": "object",
      "properties": {
        "title": { "type": "string", "maxLength": 200 },
        "description": { "type": "string", "maxLength": 1000 },
        "deadline": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "category": { "type": "string", "enum": ["school", "personal", "followup", "project", "email", "admin"] },
        "status": { "type": "string", "enum": ["pending", "in_progress", "done", "waiting", "cancelled"] },
        "source": { "type": "string", "enum": ["auto", "manual"] },
        "createdAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["title", "priority", "category", "status", "userId"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "A scheduled event in the timetable",
      "type": "object",
      "properties": {
        "title": { "type": "string", "maxLength": 200 },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "location": { "type": "string", "maxLength": 100 },
        "description": { "type": "string", "maxLength": 500 },
        "createdAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["title", "start", "end", "userId"]
    },
    "MemoryItem": {
      "title": "Memory Item",
      "description": "A piece of information remembered by the AI",
      "type": "object",
      "properties": {
        "key": { "type": "string", "maxLength": 100 },
        "value": { "type": "string", "maxLength": 1000 },
        "category": { "type": "string", "enum": ["general", "preferences", "people", "school", "patterns"] },
        "createdAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["key", "value", "category", "userId"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the chat history",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string", "maxLength": 10000 },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["role", "content", "timestamp", "userId"]
    },
    "Student": {
      "title": "Student",
      "description": "A student record detailing subjects, stream, sociology enrolment, and evidence.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "maxLength": 200 },
        "firstName": { "type": "string", "maxLength": 100 },
        "lastName": { "type": "string", "maxLength": 100 },
        "classSection": { "type": "string", "maxLength": 10 },
        "rollNumber": { "type": "string", "maxLength": 50 },
        "admissionNumber": { "type": "string", "maxLength": 50 },
        "subjects": { "type": "array" },
        "subjectCombination": { "type": "string", "maxLength": 500 },
        "stream": { "type": "string", "maxLength": 100 },
        "sociologyStudent": { "type": "boolean" },
        "orientationGroup": { "type": "string", "maxLength": 100 },
        "house": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "maxLength": 200 },
        "phone": { "type": "string", "maxLength": 50 },
        "parentName": { "type": "string", "maxLength": 200 },
        "parentContact": { "type": "string", "maxLength": 100 },
        "notes": { "type": "string", "maxLength": 1000 },
        "sourceFiles": { "type": "array" },
        "sourceEvidence": { "type": "array" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "needsReview": { "type": "boolean" },
        "reviewReason": { "type": "string", "maxLength": 500 },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["fullName", "firstName", "lastName", "classSection", "subjects", "sociologyStudent", "confidence", "needsReview", "userId"]
    },
    "TimetableEntry": {
      "title": "Timetable Entry",
      "description": "A scheduled class period for the teacher",
      "type": "object",
      "properties": {
        "teacherName": { "type": "string", "maxLength": 100 },
        "teacherCode": { "type": "string", "maxLength": 10 },
        "department": { "type": "string", "maxLength": 100 },
        "subject": { "type": "string", "maxLength": 100 },
        "classSection": { "type": "string", "maxLength": 50 },
        "day": { "type": "string", "maxLength": 20 },
        "period": { "type": "string", "maxLength": 20 },
        "startTime": { "type": "string", "maxLength": 20 },
        "endTime": { "type": "string", "maxLength": 20 },
        "venue": { "type": "string", "maxLength": 100 },
        "room": { "type": "string", "maxLength": 50 },
        "sourceFile": { "type": "string", "maxLength": 100 },
        "sourcePage": { "type": "integer" },
        "originalText": { "type": "string", "maxLength": 500 },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "needsReview": { "type": "boolean" },
        "reviewReason": { "type": "string", "maxLength": 500 },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": [
        "teacherName",
        "teacherCode",
        "subject",
        "classSection",
        "day",
        "period",
        "sourceFile",
        "confidence",
        "needsReview",
        "userId"
      ]
    }
  },
  "firestore": {
    "users/{userId}/tasks": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks belonging to a user"
    },
    "users/{userId}/calendarEvents": {
      "schema": { "$ref": "#/entities/CalendarEvent" },
      "description": "Calendar events belonging to a user"
    },
    "users/{userId}/memoryItems": {
      "schema": { "$ref": "#/entities/MemoryItem" },
      "description": "Memory items for the AI assistant context belonging to a user"
    },
    "users/{userId}/chatMessages": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat log history belonging to a user"
    },
    "users/{userId}/students": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Class student database records belonging to a user"
    },
    "users/{userId}/timetableEntries": {
      "schema": { "$ref": "#/entities/TimetableEntry" },
      "description": "Timetable scheduled entries belonging to a user"
    }
  }
}
